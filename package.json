  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Amr-Ma7moud/CampusConnect-backend/issues"
  },
  "homepage": "https://github.com/Amr-Ma7moud/CampusConnect-backend#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.4.5",
    "mongoose": "^9.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
