{
  "name": "campusconnect-backend",
  "version": "1.0.0",
  "description": "\"We Will Use EPRESS JS as you wanted\"",
  "main": "/src/server.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:unit": "cross-env NODE_ENV=test SKIP_DB_SETUP=1 NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:api": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest tests/api",
    "start": "bun src/server.js",
    "dev": "bun --watch --env-file=.env src/server.js",
    "seed": "node src/scripts/seedData.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amr-Ma7moud/CampusConnect-backend.git"
  },
